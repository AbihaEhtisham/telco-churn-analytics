cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
build/
dist/
.next/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ml-service/models/*.pkl
ml-service/models/*.joblib
*.h5
*.keras

# Data
server/data/*.csv
!server/data/sample_data.csv

# Docker
docker-volumes/

# Coverage
coverage/
.nyc_output

# Misc
.cache/
temp/
tmp/
EOF

echo "✅ .gitignore created"